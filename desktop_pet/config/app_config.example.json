{
  "app": {
    "name": "Desktop AI Pet",
    "character_name": "小胡",
    "version": "1.0"
  },
  "api": {
    "provider": "deepseek",
    "base_url": "https://api.deepseek.com",
    "model": "deepseek-chat",
    "api_key": "",
    "enable_chat_api": true,
    "timeout_seconds": 30,
    "max_recent_messages": 15,
    "summary_trigger_rounds": 30
  },
  "ui": {
    "always_on_top": true,
    "scale": 0.65,
    "enable_free_move": false,
    "click_to_chat": true,
    "start_position": "bottom_right",
    "remember_last_position": true,
    "show_test_menu": false,
    "show_clear_menu": false
  },
  "behavior": {
    "do_not_disturb": false,
    "proactive_chat": true,
    "startup_greeting": true,
    "min_proactive_interval_minutes": 20,
    "max_consecutive_active_replies": 5,
    "max_local_lines_per_day": 50,
    "max_api_proactive_per_day": 30
  },
  "chat": {
    "formal_qa_mode": false,
    "formal_answer_display": "new_panel",
    "force_summarize_before_clear": true
  },
  "proactive_content_ratio": {
    "extra_knowledge": 0.5,
    "regular_greeting": 0.5
  }
}
