{
  "app": {
    "name": "Desktop AI Pet",
    "character_name": "小胡",
    "version": "1.0"
  },
  "api": {
    "provider": "deepseek",
    "base_url": "https://api.deepseek.com",
    "model": "deepseek-v4-flash",
    "api_key": "",
    "enable_chat_api": true,
    "timeout_seconds": 30,
    "max_recent_messages": 27,
    "summary_trigger_rounds": 37
  },
  "ui": {
    "always_on_top": true,
    "scale": 0.6,
    "enable_free_move": true,
    "click_to_chat": true,
    "start_position": "bottom_right",
    "remember_last_position": true,
    "bubble_durations_ms": {
      "startup_greeting": 7000,
      "period_greeting": 7000,
      "proactive_greeting": 6000,
      "assistant_reply": 15000
    },
    "show_test_menu": false,
    "show_clear_menu": false,
    "show_reload_config": false
  },
  "behavior": {
    "do_not_disturb": false,
    "proactive_chat": true,
    "startup_greeting": true,
    "min_proactive_interval_minutes": 20,
    "max_consecutive_active_replies": 5,
    "max_local_lines_per_day": 50,
    "max_api_proactive_per_day": 30
  },
  "chat": {
    "formal_qa_mode": false,
    "formal_answer_display": "new_panel",
    "force_summarize_before_clear": true
  },
  "memory": {
    "enable_mem0": false,
    "mem0_write_mode": "shadow",
    "inject_mem0_to_prompt": false,
    "use_mem0_for_knowledge_speak": false,
    "mem0_user_id": "default_user",
    "mem0_search_top_k": 5,
    "mem0_llm_provider": "deepseek",
    "mem0_use_app_deepseek_config": true,
    "mem0_deepseek_model": "",
    "mem0_deepseek_base_url": "",
    "mem0_temperature": 0.2,
    "mem0_max_tokens": 2000,
    "mem0_top_p": 1.0,
    "mem0_embedder_provider": "dashscope_openai_compatible",
    "dashscope_api_key": "",
    "dashscope_api_key_env": "DASHSCOPE_API_KEY",
    "dashscope_embedding_base_url": "https://dashscope.aliyuncs.com/compatible-mode/v1",
    "dashscope_embedding_model": "text-embedding-v4",
    "dashscope_embedding_dimensions": 1024,
    "dashscope_embedding_encoding_format": "float",
    "write_sensitive_memory": false,
    "mem0_init_timeout_seconds": 10,
    "mem0_note": "Mem0 is optional. Keep disabled unless dependencies and API/embedder configuration are ready."
  },
  "proactive_content_ratio": {
    "extra_knowledge": 0.5,
    "regular_greeting": 0.5
  }
}
